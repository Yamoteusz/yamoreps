# =====================
# Admin
# =====================
ADMIN_PASSWORD=zmienmnie
SESSION_SECRET=tajny-secret-zmien-mnie

# =====================
# GitHub auto-commit (CMS → push → Cloudflare rebuild)
#
# Bez tych zmiennych admin działa, ale zmiany żyją tylko w pamięci.
# Z tymi zmiennymi każda mutacja commituje data/products.json do repo,
# co triggeruje Cloudflare Pages rebuild.
# =====================
GITHUB_TOKEN=ghp_xxx          # fine-grained PAT z Contents: Read & Write
GITHUB_REPO=user/yamoreps     # owner/repo
GITHUB_BRANCH=main            # opcjonalnie

# =====================
# Public
# =====================
NEXT_PUBLIC_SITE_URL=https://yamoreps.pages.dev
